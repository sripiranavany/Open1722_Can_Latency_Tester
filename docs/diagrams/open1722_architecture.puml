@startuml Open1722 CAN Latency Test Architecture

title Open1722 CAN Round-Trip Latency Measurement

skinparam componentStyle rectangle
skinparam defaultFontName Monospaced
skinparam defaultFontSize 12
skinparam backgroundColor white
skinparam ArrowColor #444441
skinparam ArrowThickness 1.5

skinparam component {
    BackgroundColor<<stm32>> #EEEDFE
    BorderColor<<stm32>> #534AB7
    FontColor<<stm32>> #26215C

    BackgroundColor<<rpi>> #E1F5EE
    BorderColor<<rpi>> #0F6E56
    FontColor<<rpi>> #04342C

    BackgroundColor<<transceiver>> #F1EFE8
    BorderColor<<transceiver>> #5F5E5A
    FontColor<<transceiver>> #2C2C2A

    BackgroundColor<<bus>> #FAEEDA
    BorderColor<<bus>> #BA7517
    FontColor<<bus>> #412402

    BackgroundColor<<ethernet>> #E1F5EE
    BorderColor<<ethernet>> #0F6E56
    FontColor<<ethernet>> #04342C
}

'--- STM32 ---
package "STM32 F439ZI  (Zephyr RTOS)" <<stm32>> {
    component [CAN1\nPD0 / PD1\nt0: send frame] as CAN1 <<stm32>>
    component [CAN2\nPB5 / PB6\nt3: receive frame] as CAN2 <<stm32>>
    note bottom of CAN1
        latency = t3 - t0
        measured entirely on STM32
    end note
}

'--- Transceivers ---
component [Transceiver 1\nSN65HVD230] as TR1 <<transceiver>>
component [Transceiver 2\nSN65HVD230] as TR2 <<transceiver>>

'--- CAN Buses ---
component [CAN Bus A\n120Ω termination] as BUSA <<bus>>
component [CAN Bus B\n120Ω termination] as BUSB <<bus>>

'--- Raspberry Pis ---
package "Raspberry Pi 1  (Linux)" <<rpi>> {
    component [CAN HAT\nt1: receive] as RPI1CAN <<rpi>>
    component [Open1722\nencapsulate → IEEE 1722] as RPI1ETH <<rpi>>
}

package "Raspberry Pi 2  (Linux)" <<rpi>> {
    component [Open1722\ndecapsulate ← IEEE 1722] as RPI2ETH <<rpi>>
    component [CAN HAT\nt2: send] as RPI2CAN <<rpi>>
}

'--- Ethernet ---
component [Direct Ethernet Cable\nIEEE 1722 / Open1722] as ETH <<ethernet>>

'--- Connections ---
CAN1 --> TR1 : TX
TR1  --> BUSA : CANH / CANL
BUSA --> RPI1CAN : CANH / CANL
RPI1CAN --> RPI1ETH : CAN frame
RPI1ETH --> ETH : UDP / IEEE 1722 packet
ETH --> RPI2ETH : UDP / IEEE 1722 packet
RPI2ETH --> RPI2CAN : CAN frame
RPI2CAN --> BUSB : CANH / CANL
BUSB --> TR2 : CANH / CANL
TR2  --> CAN2 : RX

@enduml
